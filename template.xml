<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>{{ title }}</title>
		<link rel="icon" href="{{ icon }}" />
		{% if pandoc %}
			$if(highlighting-css)$
				<style>
					$highlighting-css$
				</style>
			$endif$
			$if(math)$
				$math$
			$endif$
		{% endif %}
		<link rel="stylesheet" href="{{ style }}" />
		<script
			async
			data-goatcounter="https://gregorylimeurhen.goatcounter.com/count"
			src="https://gc.zgo.at/count.js"
		></script>
	</head>
	<body>
		<img icon src="{{ icon }}" />
		{% if posts is defined %}
		<toc>
			{% for post in posts %}
			<p>{{ post.time }}</p>
			<a href="{{ post.href }}">{{ post.title }}</a>
			{% endfor %}
		</toc>
		{% else %}
		<article>
			{{ article }}
		</article>
		{% endif %}
		<img src="https://gregorylimeurhen.goatcounter.com/counter/TOTAL.svg?no_branding" />
	</body>
</html>
