<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>{{ title }}</title>
		<link rel="icon" href="{{ favicon }}" />
		{% if pandoc %}
			$if(highlighting-css)$
				<style>
					$highlighting-css$
				</style>
			$endif$
			$if(math)$
				$math$
			$endif$
		{% endif %}
		<link rel="stylesheet" href="{{ style }}" />
		<script
			async
			data-goatcounter="https://gregorylimeurhen.goatcounter.com/count"
			src="https://gc.zgo.at/count.js"
		></script>
	</head>
	<body>
		<a href="#">
			<img icon src="{{ favicon }}" />
		</a>
		{% if posts is defined %}
			<table toc>
				{% for post in posts %}
				<tr>
					<td>{{ post.time }}</td>
					<td><a href="{{ post.href }}">{{ post.title }}</a></td>
				</tr>
				{% endfor %}
			</table>
		{% else %}
			<article>
				{{ article }}
			</article>
		{% endif %}
		<counter></counter>
		<script>
			fetch("https://gregorylimeurhen.goatcounter.com/counter/TOTAL.json")
				.then(r => r.json())
				.then(r => document.querySelector("counter").textContent = r.count)
		</script>
	</body>
</html>
